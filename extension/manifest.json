{
  "manifest_version": 3,
  "name": "HireLevel Capture",
  "description": "Capture LinkedIn and Glassdoor job details into the offline HireLevel board.",
  "version": "2.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.linkedin.com/jobs/collections/*",
    "https://glassdoor.com/*",
    "https://www.glassdoor.com/*",
    "https://*.glassdoor.com/*",
    "file:///*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://www.linkedin.com/jobs/collections/*"],
      "js": ["linkedin-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://glassdoor.com/*", "https://www.glassdoor.com/*", "https://*.glassdoor.com/*"],
      "js": ["glassdoor-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["board-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "HireLevel Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
