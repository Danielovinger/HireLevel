{
  "manifest_version": 3,
  "name": "HireLevel Capture",
  "description": "Capture job details from LinkedIn, Glassdoor, and other job sites into the offline HireLevel board.",
  "version": "2.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "file:///*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://www.linkedin.com/jobs/collections/*"],
      "js": ["linkedin-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://glassdoor.com/*", "https://www.glassdoor.com/*", "https://*.glassdoor.com/*"],
      "js": ["glassdoor-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/collections/*",
        "https://glassdoor.com/*",
        "https://www.glassdoor.com/*",
        "https://*.glassdoor.com/*"
      ],
      "js": ["generic-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["board-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "HireLevel Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
