{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HireLevel",
  "version": "1.0.0",
  "identifier": "com.hirelevel.app",
  "build": {
    "frontendDist": "../desktop-dist",
    "beforeBuildCommand": "npm run prepare:desktop",
    "beforeDevCommand": "npm run prepare:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "HireLevel",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
